;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;; Protocol Configuration Singleton (A.3) — Populis on-chain config holder.
;;;
;;; Replaces three off-chain trust roots that the Populis API previously
;;; carried as environment variables:
;;;
;;;   POPULIS_POOL_LAUNCHER_ID            -> POOL_LAUNCHER_ID (curried)
;;;   POPULIS_GOVERNANCE_LAUNCHER_ID      -> GOV_TRACKER_LAUNCHER_ID (curried)
;;;   POPULIS_NETWORK                     -> NETWORK_ID (curried)
;;;
;;; Off-chain consumers (the API at /protocol, the EIP-712 registration
;;; envelope, the frontend) all bind to the puzzle's curried state via the
;;; deterministic ``content_hash`` defined below.  This closes the
;;; "stale .env on operator deployment" trust gap (POP-CANON-002 /
;;; POP-CANON-005) and the "config drift between /auth/challenge and
;;; /vault/register" race window.
;;;
;;; Curried parameters:
;;;   SELF_MOD_HASH           — tree hash of THIS module (for self-recurry).
;;;                             Provided as a curried arg because we cannot
;;;                             reference our own hash from inside the
;;;                             puzzle body otherwise.
;;;   GOV_PUBKEY              — BLS pubkey of the protocol governance
;;;                             authority.  Only this key can spend the
;;;                             singleton to update its state.  Rotation
;;;                             of GOV_PUBKEY itself is intentionally NOT
;;;                             supported here — that's the admin-authority
;;;                             singleton's job (see A.2).
;;;   POOL_LAUNCHER_ID        — current protocol pool singleton launcher.
;;;   GOV_TRACKER_LAUNCHER_ID — current governance-tracker singleton.
;;;   NETWORK_ID              — bytes32 marker for the chain network
;;;                             (we use the AGG_SIG_ME genesis challenge
;;;                             of the target network: testnet11 or mainnet).
;;;   CONFIG_VERSION          — uint64; monotonically increases on every
;;;                             update.  Replay-attack guard.
;;;
;;; Solution:
;;;   my_amount                       — singleton's coin amount (must be odd)
;;;   new_pool_launcher_id            — bytes32, replacement POOL_LAUNCHER_ID
;;;   new_gov_tracker_launcher_id     — bytes32, replacement GOV_TRACKER
;;;   new_network_id                  — bytes32, replacement NETWORK_ID
;;;   new_config_version              — uint64, must be > CONFIG_VERSION
;;;
;;; Output conditions on a valid update spend:
;;;   AGG_SIG_ME GOV_PUBKEY <new_state_hash>
;;;     Governance authorizes the new state.  Signature commits to ALL
;;;     four new values plus the new version, so partial-update or
;;;     stale-signature attacks are impossible.
;;;
;;;   CREATE_COIN <new_inner_puzhash> my_amount
;;;     Recreate self with new state.  The CREATE_COIN destination is the
;;;     INNER puzzle hash; the singleton wrapper auto-morphs it to the
;;;     full singleton puzzle hash.
;;;
;;;   CREATE_PUZZLE_ANNOUNCEMENT <PROTOCOL_PREFIX || content_hash(new_state)>
;;;     Off-chain consumers (the API's coinset.org indexer) treat this
;;;     announcement as the "config-published" event and update their
;;;     cached state.
;;;
;;;   ASSERT_MY_AMOUNT my_amount
;;;     Defensive — ties the singleton's amount to the solution param.
;;;
;;; Content hash:
;;;   content_hash(state) = sha256tree(list POOL_LAUNCHER_ID
;;;                                         GOV_TRACKER_LAUNCHER_ID
;;;                                         NETWORK_ID
;;;                                         CONFIG_VERSION)
;;;
;;;   This is what the EIP-712 registration envelope's `protocolConfigHash`
;;;   field binds to.  The user's wallet cannot display the launcher_ids
;;;   meaningfully, but the hash is verifiable: the frontend recomputes
;;;   it against the on-chain singleton state before prompting the user
;;;   to sign.
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(mod
  (
    SELF_MOD_HASH
    GOV_PUBKEY
    POOL_LAUNCHER_ID
    GOV_TRACKER_LAUNCHER_ID
    NETWORK_ID
    CONFIG_VERSION
    ;; --- solution ---
    my_amount
    new_pool_launcher_id
    new_gov_tracker_launcher_id
    new_network_id
    new_config_version
  )

  (include condition_codes.clib)
  (include curry.clib)
  (include sha256tree.clib)
  (include utility_macros.clib)

  ;; ─── content_hash: the single off-chain binding point ─────────────────
  ;;
  ;; Used by:
  ;;   * EIP-712 registration envelope's `protocolConfigHash` field.
  ;;   * The /protocol API endpoint's `protocol_config_hash` response.
  ;;   * The CREATE_PUZZLE_ANNOUNCEMENT below (with PROTOCOL_PREFIX).
  ;;
  ;; The argument order MUST match the off-chain
  ;; ``protocol_config_driver.compute_content_hash`` exactly — the test
  ;; ``test_content_hash_matches_driver`` enforces this.
  (defun-inline content-hash (pool gov_tracker network version)
    (sha256tree (list pool gov_tracker network version))
  )

  ;; ─── Self-recurry ─────────────────────────────────────────────────────
  ;;
  ;; Compute this puzzle's tree hash with new curried state.  SELF_MOD_HASH
  ;; is provided as a curried arg because Chialisp cannot otherwise
  ;; reference its own hash.  The first curried slot of the recurried
  ;; puzzle is therefore SELF_MOD_HASH itself (so the new puzzle can in
  ;; turn self-recurry on its next update).
  (defun-inline new-inner-puzhash
      (SELF_MOD_HASH GOV_PUBKEY new_pool new_gov_tracker new_network new_version)
    (curry_hashes SELF_MOD_HASH
      (sha256 1 SELF_MOD_HASH)
      (sha256 1 GOV_PUBKEY)
      (sha256 1 new_pool)
      (sha256 1 new_gov_tracker)
      (sha256 1 new_network)
      (sha256 1 new_version)
    )
  )

  (assert
    ;; Solution sanity.
    (is-uint64 my_amount)
    (is-size-b32 SELF_MOD_HASH)
    (is-size-b32 new_pool_launcher_id)
    (is-size-b32 new_gov_tracker_launcher_id)
    (is-size-b32 new_network_id)
    (is-uint64 new_config_version)
    ;; Curried sanity (defence-in-depth — these are operator-set, but a
    ;; misconfigured launch would be caught by the very first spend).
    ;; GOV_PUBKEY is 48 bytes (BLS G1) so we don't size-check it here;
    ;; AGG_SIG_ME below will reject non-G1 pubkeys at consensus time.
    (is-size-b32 POOL_LAUNCHER_ID)
    (is-size-b32 GOV_TRACKER_LAUNCHER_ID)
    (is-size-b32 NETWORK_ID)
    (is-uint64 CONFIG_VERSION)
    ;; Replay protection: version must STRICTLY increase.
    (> new_config_version CONFIG_VERSION)
    (list
      ;; (1) Governance signs the entire new state.  Note: we sign the
      ;; content_hash directly (not just an opaque message) so anyone
      ;; reviewing the chain can independently verify what was signed.
      (list AGG_SIG_ME GOV_PUBKEY
        (content-hash new_pool_launcher_id new_gov_tracker_launcher_id
                      new_network_id new_config_version))

      ;; (2) Recreate self with new state.  Singleton wrapper morphs.
      (list CREATE_COIN
        (new-inner-puzhash SELF_MOD_HASH GOV_PUBKEY
          new_pool_launcher_id new_gov_tracker_launcher_id
          new_network_id new_config_version)
        my_amount)

      ;; (3) Publish the new content hash for off-chain consumers.
      (list CREATE_PUZZLE_ANNOUNCEMENT
        (concat PROTOCOL_PREFIX
          (content-hash new_pool_launcher_id new_gov_tracker_launcher_id
                        new_network_id new_config_version)))

      ;; (4) Tie singleton amount to solution param (defensive).
      (list ASSERT_MY_AMOUNT my_amount)
    )
  )
)
