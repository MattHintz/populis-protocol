;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;; The p2 singleton puzzle for the pool
;;; Holds a Smart Deed NFT on behalf of the pool singleton.
;;; May be spent anytime authorized by the pool singleton inner puzzle.
;;; Modeled on Solslot p2_vault.clsp, adapted for pool escrow.
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(mod
    (
        SINGLETON_MOD_HASH ; the mod-hash for the singleton_top_layer puzzle
        POOL_LAUNCHER_ID ; the ID of the pool singleton we are committed to
        LAUNCHER_PUZZLE_HASH ; the puzzle hash of the launcher
        pool_inner_puzzle_hash ; the inner puzzlehash for the pool singleton at current time
        pool_coin_id ; the specific pool coin we want an announcement tied to
        deed_launcher_id ; the launcher ID of the Smart Deed NFT
        deed_inner_puzzle_hash ; the NFT's singleton inner puzzlehash
        deed_amount
        next_puzzlehash ; where the NFT coin should be sent (p2_vault or beneficiary)
    )

    ;; Include standard condition codes and utility functions
    (include condition_codes.clib)
    (include utils.clib)
    (include utility_macros.clib)

    ;; Main function to handle spends
    (defun main (
        SINGLETON_MOD_HASH
        POOL_LAUNCHER_ID
        LAUNCHER_PUZZLE_HASH
        pool_inner_puzzle_hash
        pool_coin_id
        deed_launcher_id
        deed_inner_puzzle_hash
        deed_amount
        next_puzzlehash
    )
        (assert
            (is-size-b32 pool_inner_puzzle_hash)
            (is-size-b32 pool_coin_id)
            (is-size-b32 deed_launcher_id)
            (is-size-b32 deed_inner_puzzle_hash)
            (is-uint64 deed_amount)
            (is-size-b32 next_puzzlehash)
            (list
                (list ASSERT_MY_AMOUNT deed_amount)

                ;; Prove supplied NFT coin matches the expected derived puzzle hash
                (list ASSERT_MY_PUZZLEHASH
                    (calculate_full_puzzle_hash (c SINGLETON_MOD_HASH (c deed_launcher_id LAUNCHER_PUZZLE_HASH)) deed_inner_puzzle_hash)
                )

                ;; Assert pool singleton co-spends and announces this release
                (list ASSERT_PUZZLE_ANNOUNCEMENT
                    (sha256
                        (calculate_full_puzzle_hash (c SINGLETON_MOD_HASH (c POOL_LAUNCHER_ID LAUNCHER_PUZZLE_HASH)) pool_inner_puzzle_hash)
                        (concat PROTOCOL_PREFIX (sha256tree (list pool_coin_id deed_launcher_id next_puzzlehash)))
                    )
                )

                ;; Create and move the NFT coin to next destination
                (list CREATE_COIN next_puzzlehash deed_amount (list next_puzzlehash))

                ;; Announce that a specific pool singleton is being spent
                (list CREATE_COIN_ANNOUNCEMENT (concat PROTOCOL_PREFIX (sha256 pool_coin_id deed_launcher_id next_puzzlehash)))
            )
        )
    )

    ;; Execute the main function with the provided parameters
    (main SINGLETON_MOD_HASH POOL_LAUNCHER_ID LAUNCHER_PUZZLE_HASH pool_inner_puzzle_hash pool_coin_id deed_launcher_id deed_inner_puzzle_hash deed_amount next_puzzlehash)
)
