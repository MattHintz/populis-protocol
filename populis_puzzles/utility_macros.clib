(
  ; assert takes a list of parameters
  ; all items in the list are required to be non-nil
  ; except for the final item which is returned
  (defmacro assert items
    (if (r items)
        (list if (f items) (c assert (r items)) (q . (x)))
        (f items)
    )
  )

  (defmacro and ARGS
    (if ARGS
        (qq (if (unquote (f ARGS))
                (unquote (c and (r ARGS)))
                ()
        ))
    1)
  )

  (defmacro or ARGS
    (if ARGS
        (qq (if (unquote (f ARGS))
                1
                (unquote (c or (r ARGS)))
        ))
    0)
  )

  (defun in (atom list_a)
    (if list_a
        (i (= atom (f list_a))
          1
          (in atom (r list_a))
        )
        ()
    )
  )

  (defun gte (atom_a atom_b)
    (not (> atom_b atom_a))
  )

  (defun lte (atom_a atom_b)
    (not (> atom_a atom_b))
  )

  ;; --- Input validators ---

  ;; Validate unsigned 64-bit integer: non-negative, below 2^64, canonical encoding.
  ;; Uses nested if-chain: reject negative, reject >= 2^64, then verify canonical form.
  ;; NOTE: Upper bound must be 0x10000000000000000 (positive 9-byte atom in CLVM),
  ;; not 0xFFFFFFFFFFFFFFFF (which is -1 in CLVM's signed representation).
  (defun is-uint64 (v)
    (if (> 0 v) ()
      (if (not (> 0x10000000000000000 v)) ()
        (= (+ v) v)
      )
    )
  )

  ;; Validate exactly 32-byte atom (puzzle hashes, coin IDs, launcher IDs)
  (defun-inline is-size-b32 (v)
    (= (strlen v) 32)
  )

  ;; Validate 32-byte atom or nil (optional hash fields)
  (defun-inline is-size-b32-or-nil (v)
    (if v (= (strlen v) 32) 1)
  )

  ;; Validate exactly 48-byte atom (BLS12-381 G1 compressed pubkeys).
  ;;
  ;; All A.x trust-root puzzles take BLS G1 pubkeys as curried args; without
  ;; this check the puzzle accepts an arbitrary-sized atom in the pubkey slot
  ;; and only fails when the FIRST AGG_SIG_ME executes at consensus.  A
  ;; misconfigured launch therefore bricks the singleton lineage permanently
  ;; (no valid signature exists for a malformed BLS pubkey).  See
  ;; CANON_POPULIS_TRANSPARENCY_SINGLETONS_2026_05_03.md POP-CANON-018.
  (defun-inline is-size-bls-g1 (v)
    (= (strlen v) 48)
  )

  ;; Validate every element of `lst` is a 48-byte BLS G1 pubkey.
  ;; Vacuously true for an empty list — quorum-bounds checks elsewhere
  ;; in the puzzle catch the zero-signer case.
  (defun all-bls-g1-pubkeys (lst)
    (if lst
      (if (is-size-bls-g1 (f lst))
        (all-bls-g1-pubkeys (r lst))
        ()
      )
      1
    )
  )

  ;; Validate that no two elements of `lst` are byte-equal.
  ;;
  ;; Used by admin_authority_inner.clsp to reject a `new_allowlist` that
  ;; contains the same pubkey twice — duplicates would dilute the
  ;; effective quorum (a 2-of-3 [X, X, Y] is structurally 1-of-2 since
  ;; AGG_SIG_ME on (pk_X, msg) ∧ (pk_X, msg) is satisfied by a single
  ;; X-signature).  See CANON_POPULIS_TRANSPARENCY_SINGLETONS_2026_05_03.md
  ;; POP-CANON-017.
  ;;
  ;; Internal helper: linear "is `item` in `seen`?" scan.
  ;; defun (not defun-inline) because the implementation is recursive.
  (defun atom-in-list (item seen)
    (if seen
      (if (= item (f seen))
        1
        (atom-in-list item (r seen))
      )
      ()
    )
  )

  ;; Public guard: O(n²) duplicate-detection over `lst`.
  ;; n is small for any realistic admin allowlist (typically ≤ 7).
  ;; `seen` is the recursion accumulator; callers pass `()` initially.
  (defun has-no-duplicates (lst seen)
    (if lst
      (if (atom-in-list (f lst) seen)
        ()
        (has-no-duplicates (r lst) (c (f lst) seen))
      )
      1
    )
  )

  ;; --- Protocol prefix for announcement namespacing ---

  (defconstant PROTOCOL_PREFIX 0x50)  ;; "P" for Populis

)
