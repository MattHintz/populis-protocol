;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;; p2_deed_settlement — Settlement offer leaf puzzle for batch settlement.
;;; Analogous to Solslot's p2_nft_burn_or_delayed.
;;;
;;; Each p2_deed_settlement coin is a leaf of the splitxch distribution tree,
;;; created when the pool batch-settles a collection of deeds.  It holds an
;;; equal share of the total settlement XCH for one specific deed.
;;;
;;; Two escape conditions:
;;;   1. CLAIM — burn the deed (via p2_pool release to BURN_INNER_PUZHASH)
;;;      and receive XCH to a target puzzle hash.  Verifies the deed singleton
;;;      co-spends by asserting a coin announcement from the deed's p2_pool
;;;      inner puzzle (which p2_pool emits on every spend).
;;;   2. DELAYED — after SECONDS_DELAY, anyone can claim to DELAYED_PUZZLE_HASH
;;;      (safety valve if deed holder never claims).
;;;
;;; Curried parameters:
;;;   SINGLETON_MOD_HASH    — mod hash for singleton_top_layer
;;;   DEED_LAUNCHER_ID      — launcher ID of the specific deed NFT
;;;   LAUNCHER_PUZZLE_HASH  — standard launcher puzzle hash
;;;   BURN_INNER_PUZHASH    — the inner puzzle hash the deed is sent to on burn
;;;   SECONDS_DELAY         — seconds before delayed escape is available
;;;   DELAYED_PUZZLE_HASH   — destination for delayed escape
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(mod
    (
        SINGLETON_MOD_HASH
        DEED_LAUNCHER_ID
        LAUNCHER_PUZZLE_HASH
        BURN_INNER_PUZHASH
        SECONDS_DELAY
        DELAYED_PUZZLE_HASH
        ;; --- solution ---
        ;; Claim path:  (target_puzzle_hash my_amount . extra_args)
        ;; Delayed path: (my_amount)   — extra_args is ()
        target_puzzle_hash
        my_amount
        . extra_args
    )

    (include condition_codes.clib)
    (include curry.clib)
    (include sha256tree.clib)
    (include utility_macros.clib)

    ;; Compute full singleton puzzle hash for the deed
    (defun-inline calculate_full_puzzle_hash (SINGLETON_MOD_HASH DEED_LAUNCHER_ID LAUNCHER_PUZZLE_HASH inner_puzzle_hash)
        (curry_hashes SINGLETON_MOD_HASH
            (sha256tree (c SINGLETON_MOD_HASH (c DEED_LAUNCHER_ID LAUNCHER_PUZZLE_HASH)))
            inner_puzzle_hash
        )
    )

    ;; DELAYED escape — safety valve after timeout
    (defun-inline delayed_spend (SECONDS_DELAY DELAYED_PUZZLE_HASH my_amount)
        (list
            (list ASSERT_SECONDS_RELATIVE SECONDS_DELAY)
            (list CREATE_COIN DELAYED_PUZZLE_HASH my_amount)
            (list ASSERT_MY_AMOUNT my_amount)
        )
    )

    ;; CLAIM — deed holder burns deed, receives XCH
    ;; The deed is released from p2_pool to BURN_INNER_PUZHASH by the pool
    ;; settlement transaction.  p2_pool emits a CREATE_COIN_ANNOUNCEMENT that
    ;; we assert here to verify the deed is actually being burned.
    ;; extra_args = (deed_coin_id pool_coin_id)
    (defun claim_settlement (SINGLETON_MOD_HASH DEED_LAUNCHER_ID LAUNCHER_PUZZLE_HASH
                             BURN_INNER_PUZHASH
                             target_puzzle_hash my_amount
                             deed_coin_id pool_coin_id)
        (assert
            (is-size-b32 target_puzzle_hash)
            (is-uint64 my_amount)
            (is-size-b32 deed_coin_id)
            (is-size-b32 pool_coin_id)
            (list
                ;; Assert the deed's p2_pool coin announces the burn release.
                ;; p2_pool emits: CREATE_COIN_ANNOUNCEMENT(PROTOCOL_PREFIX . sha256(pool_coin_id, deed_launcher_id, next_puzzlehash))
                ;; where next_puzzlehash = BURN_INNER_PUZHASH for settlement burns.
                ;; The coin announcement comes from the deed singleton coin (p2_pool is its inner).
                (list ASSERT_COIN_ANNOUNCEMENT
                    (sha256 deed_coin_id
                        (concat PROTOCOL_PREFIX (sha256 pool_coin_id DEED_LAUNCHER_ID BURN_INNER_PUZHASH))))

                ;; Release settlement XCH to target (beneficiary)
                (list CREATE_COIN target_puzzle_hash my_amount (list target_puzzle_hash))

                ;; Announce claim for driver hints
                (list CREATE_COIN_ANNOUNCEMENT
                    (concat PROTOCOL_PREFIX (sha256 DEED_LAUNCHER_ID target_puzzle_hash)))

                ;; Verify settlement amount
                (list ASSERT_MY_AMOUNT my_amount)
            )
        )
    )

    ;; Main dispatch: if extra_args present → claim path, else → delayed path
    (if extra_args
        (claim_settlement
            SINGLETON_MOD_HASH DEED_LAUNCHER_ID LAUNCHER_PUZZLE_HASH
            BURN_INNER_PUZHASH
            target_puzzle_hash my_amount
            (f extra_args) (f (r extra_args)))
        (delayed_spend SECONDS_DELAY DELAYED_PUZZLE_HASH my_amount)
    )
)
