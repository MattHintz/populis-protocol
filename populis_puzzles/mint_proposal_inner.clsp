;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;; Mint Proposal Singleton (A.1) — per-proposal on-chain state machine.
;;;
;;; Replaces the SQLite-backed ``MintProposalStore`` table with a
;;; per-proposal singleton coin whose state evolves through a tightly
;;; constrained state machine.  The launcher_id of each proposal
;;; singleton IS the unique proposal identifier on-chain, and the
;;; singleton's lineage is the full history of state transitions.
;;;
;;; State machine:
;;;
;;;   ┌─────┐  AGG_SIG_ME GOV   ┌──────────┐
;;;   │DRAFT│ ─────────────────▶│ APPROVED │
;;;   └─────┘                   └──────────┘
;;;       │                         │
;;;       │ AGG_SIG_ME OWNER        │ AGG_SIG_ME GOV (V2: + EXECUTE)
;;;       ▼                         ▼
;;;   ┌─────────┐               ┌──────────┐
;;;   │CANCELLED│               │CANCELLED │  (only via gov; V2 work)
;;;   └─────────┘               └──────────┘
;;;
;;; V1 scope (this file):
;;;   * DRAFT  → APPROVED   (TRANSITION_APPROVE = 'a' / 0x61, gov-signed)
;;;   * DRAFT  → CANCELLED  (TRANSITION_CANCEL  = 'c' / 0x63, owner-signed)
;;;
;;; V2 work (deferred):
;;;   * APPROVED → EXECUTED ('x' / 0x78), gated by ASSERT_COIN_ANNOUNCEMENT
;;;     from the actual PGT-driven mint.  Requires cross-coin
;;;     coordination with populis_protocol/governance_singleton_inner.
;;;   * APPROVED → CANCELLED via governance (with cooldown / quorum).
;;;
;;; Curried parameters:
;;;   SELF_MOD_HASH         — tree hash of THIS module (self-recurry).
;;;   OWNER_PUBKEY          — BLS G1, can cancel from DRAFT.
;;;   GOV_PUBKEY            — BLS G1, can approve from DRAFT.
;;;   PROPOSAL_DATA_HASH    — opaque bytes32; off-chain canonical hash
;;;                           of (property_id, par_value, royalty_bps,
;;;                           quorum_threshold).  Stored as a hash to
;;;                           avoid bloating the curried state; the
;;;                           full data is published off-chain at launch
;;;                           time and re-derivable from the launcher
;;;                           coin's spend bundle.
;;;   PROPOSAL_STATE        — uint: 1=DRAFT, 2=APPROVED, 3=CANCELLED.
;;;   STATE_VERSION         — uint, monotonically increases.
;;;
;;; Solution:
;;;   my_amount             — singleton coin amount (odd).
;;;   transition_case       — 'a' (0x61) APPROVE | 'c' (0x63) CANCEL.
;;;   new_state_version     — uint, must be > STATE_VERSION.
;;;
;;; Output conditions on a valid spend:
;;;   AGG_SIG_ME <signer_pubkey> <message>
;;;     Per-transition signer:
;;;       APPROVE: GOV_PUBKEY signs hash(transition_case, new_version)
;;;       CANCEL : OWNER_PUBKEY signs hash(transition_case, new_version)
;;;
;;;   CREATE_COIN <new_inner_puzhash> my_amount
;;;     Recreate self with new state + version.  Singleton wrapper morphs.
;;;
;;;   CREATE_PUZZLE_ANNOUNCEMENT <PROTOCOL_PREFIX || transition_msg>
;;;     Off-chain consumers track this announcement to update cached
;;;     proposal state.  ``transition_msg`` =
;;;     sha256tree(list transition_case new_state new_version).
;;;
;;;   ASSERT_MY_AMOUNT my_amount
;;;     Defensive identity check.
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(mod
  (
    SELF_MOD_HASH
    OWNER_PUBKEY
    GOV_PUBKEY
    PROPOSAL_DATA_HASH
    PROPOSAL_STATE
    STATE_VERSION
    ;; --- solution ---
    my_amount
    transition_case
    new_state_version
  )

  (include condition_codes.clib)
  (include utils.clib)
  (include utility_macros.clib)

  ;; ─── State + transition constants ────────────────────────────────────

  (defconstant STATE_DRAFT     1)
  (defconstant STATE_APPROVED  2)
  (defconstant STATE_CANCELLED 3)

  (defconstant TRANSITION_APPROVE 0x61)  ;; 'a'
  (defconstant TRANSITION_CANCEL  0x63)  ;; 'c'

  ;; ─── Self-recurry ────────────────────────────────────────────────────

  (defun-inline new-inner-puzhash
      (SELF_MOD_HASH OWNER_PUBKEY GOV_PUBKEY PROPOSAL_DATA_HASH
       new_state new_state_version)
    (curry_hashes SELF_MOD_HASH
      (sha256 1 SELF_MOD_HASH)
      (sha256 1 OWNER_PUBKEY)
      (sha256 1 GOV_PUBKEY)
      (sha256 1 PROPOSAL_DATA_HASH)
      (sha256 1 new_state)
      (sha256 1 new_state_version)
    )
  )

  ;; ─── Signing message + transition announcement ──────────────────────

  ;; Binds the signer's AGG_SIG_ME to BOTH the transition case AND the
  ;; new version slot.  A signature for transition X at version V can
  ;; never be replayed for transition Y or version W.
  (defun-inline signing-message (transition_case new_state_version)
    (sha256tree (list transition_case new_state_version))
  )

  ;; Off-chain consumers (the API indexer) read this announcement
  ;; payload to update cached proposal state.  Includes new_state so
  ;; consumers don't need to know the transition_case → new_state map.
  (defun-inline transition-message (transition_case new_state new_state_version)
    (sha256tree (list transition_case new_state new_state_version))
  )

  ;; ─── Per-transition condition builders ──────────────────────────────

  ;; APPROVE: state must be DRAFT, gov signs, new state = APPROVED.
  (defun approve-conditions
      (SELF_MOD_HASH OWNER_PUBKEY GOV_PUBKEY PROPOSAL_DATA_HASH
       my_amount new_state_version)
    (list
      (list AGG_SIG_ME GOV_PUBKEY
        (signing-message TRANSITION_APPROVE new_state_version))
      (list CREATE_COIN
        (new-inner-puzhash SELF_MOD_HASH OWNER_PUBKEY GOV_PUBKEY
          PROPOSAL_DATA_HASH STATE_APPROVED new_state_version)
        my_amount)
      (list CREATE_PUZZLE_ANNOUNCEMENT
        (concat PROTOCOL_PREFIX
          (transition-message TRANSITION_APPROVE STATE_APPROVED new_state_version)))
      (list ASSERT_MY_AMOUNT my_amount)
    )
  )

  ;; CANCEL_FROM_DRAFT: state must be DRAFT, owner signs, new state = CANCELLED.
  (defun cancel-conditions
      (SELF_MOD_HASH OWNER_PUBKEY GOV_PUBKEY PROPOSAL_DATA_HASH
       my_amount new_state_version)
    (list
      (list AGG_SIG_ME OWNER_PUBKEY
        (signing-message TRANSITION_CANCEL new_state_version))
      (list CREATE_COIN
        (new-inner-puzhash SELF_MOD_HASH OWNER_PUBKEY GOV_PUBKEY
          PROPOSAL_DATA_HASH STATE_CANCELLED new_state_version)
        my_amount)
      (list CREATE_PUZZLE_ANNOUNCEMENT
        (concat PROTOCOL_PREFIX
          (transition-message TRANSITION_CANCEL STATE_CANCELLED new_state_version)))
      (list ASSERT_MY_AMOUNT my_amount)
    )
  )

  ;; ─── Main dispatch ───────────────────────────────────────────────────

  (assert
    (is-uint64 my_amount)
    (is-size-b32 SELF_MOD_HASH)
    (is-size-b32 PROPOSAL_DATA_HASH)
    (is-uint64 new_state_version)
    (is-uint64 PROPOSAL_STATE)
    (is-uint64 STATE_VERSION)
    ;; Replay protection: monotonic version.
    (> new_state_version STATE_VERSION)
    ;; The current state must be DRAFT for any V1 transition.  V2
    ;; relaxes this when EXECUTE / governance-cancel land.
    (= PROPOSAL_STATE STATE_DRAFT)
    ;; Dispatch on transition case.
    (if (= transition_case TRANSITION_APPROVE)
      (approve-conditions
        SELF_MOD_HASH OWNER_PUBKEY GOV_PUBKEY PROPOSAL_DATA_HASH
        my_amount new_state_version)
      (if (= transition_case TRANSITION_CANCEL)
        (cancel-conditions
          SELF_MOD_HASH OWNER_PUBKEY GOV_PUBKEY PROPOSAL_DATA_HASH
          my_amount new_state_version)
        (x)  ;; unknown transition — refuse
      )
    )
  )
)
