;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;; PGT free-state inner puzzle.
;;;
;;; This is the CAT2 inner puzzle attached to every PGT coin while it is
;;; freely transferable / available for governance participation.  Every
;;; non-locked PGT coin in existence has this exact mod with appropriate
;;; INNER_PUZZLE_HASH curried in.
;;;
;;; Two spend cases:
;;;   1 — TRANSFER : run the user's inner puzzle, replace its single
;;;                  CREATE_COIN with one whose puzhash is a re-curry of
;;;                  pgt_free_inner around the requested new owner hash.
;;;                  All other inner conditions pass through unchanged
;;;                  except that REMARK / SEND_MESSAGE / RECEIVE_MESSAGE
;;;                  using the populis PROTOCOL_PREFIX are rejected so a
;;;                  malicious inner puzzle cannot spoof governance traffic.
;;;
;;;   2 — LOCK     : commit this PGT coin to a specific proposal hash for
;;;                  a fixed deadline.  The user's inner puzzle authorises
;;;                  the action by signing a delegated puzzle that emits
;;;                  exactly one CREATE_COIN whose target equals the
;;;                  pgt_locked_inner full puzzle hash for those params.
;;;
;;; Curried parameters (immutable per PGT lineage):
;;;   MOD_HASH                — self-reference (this mod's tree hash)
;;;   LOCKED_MOD_HASH         — pgt_locked_inner mod hash (re-curry target)
;;;   PROPOSAL_TRACKER_STRUCT — singleton struct of the tracker.
;;;   INNER_PUZZLE_HASH       — current owner's user puzzle hash.
;;;
;;; Solution shape:
;;;   spend_case        — 1 (TRANSFER) | 2 (LOCK)
;;;   inner_puzzle      — reveal of the user's puzzle (must hash to INNER_PUZZLE_HASH)
;;;   inner_solution    — the user's solution
;;;   case_args         — TRANSFER: ()
;;;                     — LOCK: (proposal_hash deadline my_amount)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
(mod (
        MOD_HASH
        LOCKED_MOD_HASH
        PROPOSAL_TRACKER_STRUCT
        INNER_PUZZLE_HASH
        ;; --- solution ---
        spend_case
        inner_puzzle
        inner_solution
        case_args
     )

    (include condition_codes.clib)
    (include utils.clib)
    (include utility_macros.clib)

    ;; Spend case constants
    (defconstant PGT_TRANSFER 1)
    (defconstant PGT_LOCK 2)

    ;; LOCK announcement tag (4 ASCII bytes "LOCK")
    (defconstant LOCK_TAG 0x4c4f434b)

    ;; ----- Recursive condition filters -----
    ;; Each defun receives every mod-level arg it needs as an explicit
    ;; parameter — this dialect of Chialisp does not give regular defuns
    ;; access to the mod environment, so passing them through is mandatory.

    ;; Reject any condition that could spoof governance traffic:
    ;;   - REMARK whose first arg is PROTOCOL_PREFIX  (governance REMARKs)
    ;;   - any SEND_MESSAGE or RECEIVE_MESSAGE        (all messaging is the
    ;;     PGT wrapper's responsibility; inner puzzles must never emit them)
    ;; PROTOCOL_PREFIX is a defconstant from utility_macros.clib (a literal).
    (defun-inline check_no_protocol_prefix_abuse (cond_code cond_body)
        (if (= cond_code REMARK)
            (if (= (f cond_body) PROTOCOL_PREFIX) (x) 1)
            (if (any (= cond_code SEND_MESSAGE) (= cond_code RECEIVE_MESSAGE))
                (x)
                1))
    )

    ;; Compute the puzzle hash of pgt_free_inner curried with a given owner.
    (defun-inline compute_self_free_puzhash
            (mod_hash locked_mod_hash tracker_struct new_inner_hash)
        (curry_hashes mod_hash
            (sha256 1 mod_hash)
            (sha256 1 locked_mod_hash)
            (sha256tree tracker_struct)
            (sha256 1 new_inner_hash))
    )

    ;; Compute the puzzle hash of pgt_locked_inner for given lock params.
    (defun-inline compute_locked_puzhash
            (mod_hash locked_mod_hash tracker_struct owner_inner_hash
             proposal_hash deadline)
        (curry_hashes locked_mod_hash
            (sha256 1 locked_mod_hash)
            (sha256 1 mod_hash)
            (sha256tree tracker_struct)
            (sha256 1 owner_inner_hash)
            (sha256 1 proposal_hash)
            (sha256 1 deadline))
    )

    ;; Walk the conditions list for TRANSFER mode: rewrap the single
    ;; CREATE_COIN's destination, anti-spoof everything else, return the
    ;; transformed list.
    (defun filter_transfer
            (mod_hash locked_mod_hash tracker_struct
             conditions found_create_coin acc)
        (if conditions
            (if (= (f (f conditions)) CREATE_COIN)
                (assert
                    (not found_create_coin)
                    (is-size-b32 (f (r (f conditions))))
                    (is-uint64 (f (r (r (f conditions)))))
                    (filter_transfer mod_hash locked_mod_hash tracker_struct
                        (r conditions) 1
                        (c
                            (list CREATE_COIN
                                (compute_self_free_puzhash
                                    mod_hash locked_mod_hash tracker_struct
                                    (f (r (f conditions))))
                                (f (r (r (f conditions))))
                                (list (f (r (f conditions)))))
                            acc)))
                (assert
                    (check_no_protocol_prefix_abuse
                        (f (f conditions)) (r (f conditions)))
                    (filter_transfer mod_hash locked_mod_hash tracker_struct
                        (r conditions) found_create_coin
                        (c (f conditions) acc))))
            (assert found_create_coin acc))
    )

    ;; Walk the conditions list for LOCK mode: verify the single CREATE_COIN
    ;; goes to the expected pgt_locked_inner puzhash, and pass through other
    ;; conditions (with the same anti-spoof check).
    (defun filter_lock
            (conditions expected_locked_puzhash my_amount
             found_create_coin acc)
        (if conditions
            (if (= (f (f conditions)) CREATE_COIN)
                (assert
                    (not found_create_coin)
                    (= (f (r (f conditions))) expected_locked_puzhash)
                    (= (f (r (r (f conditions)))) my_amount)
                    (filter_lock (r conditions) expected_locked_puzhash my_amount
                        1 (c (f conditions) acc)))
                (assert
                    (check_no_protocol_prefix_abuse
                        (f (f conditions)) (r (f conditions)))
                    (filter_lock (r conditions) expected_locked_puzhash my_amount
                        found_create_coin (c (f conditions) acc))))
            (assert found_create_coin acc))
    )

    ;; ----- Top-level dispatcher (mod-level args available here) -----
    (assert
        (is-size-b32 INNER_PUZZLE_HASH)
        (if (= spend_case PGT_TRANSFER)
            (assert
                (= (sha256tree inner_puzzle) INNER_PUZZLE_HASH)
                (filter_transfer
                    MOD_HASH LOCKED_MOD_HASH PROPOSAL_TRACKER_STRUCT
                    (a inner_puzzle inner_solution) 0 ()))
            (if (= spend_case PGT_LOCK)
                (assert
                    (is-size-b32 (f case_args))           ; proposal_hash
                    (is-uint64 (f (r case_args)))         ; deadline
                    (is-uint64 (f (r (r case_args))))     ; my_amount
                    (= (sha256tree inner_puzzle) INNER_PUZZLE_HASH)
                    (c
                        ;; Lock announcement for the proposal tracker.
                        (list CREATE_PUZZLE_ANNOUNCEMENT
                            (concat PROTOCOL_PREFIX
                                (sha256tree
                                    (list LOCK_TAG
                                        (f case_args)             ; proposal_hash
                                        (f (r (r case_args)))     ; my_amount
                                        (f (r case_args))))))     ; deadline
                        (c
                            ;; Lock window: must be spent before the deadline.
                            (list ASSERT_BEFORE_SECONDS_ABSOLUTE (f (r case_args)))
                            (filter_lock
                                (a inner_puzzle inner_solution)
                                (compute_locked_puzhash
                                    MOD_HASH LOCKED_MOD_HASH PROPOSAL_TRACKER_STRUCT
                                    INNER_PUZZLE_HASH
                                    (f case_args) (f (r case_args)))
                                (f (r (r case_args)))
                                0 ()))))
                (x))))
)
